# ABsmartly E2E Test Configuration
# Copy to e2e-config.env and fill in real values
ABSMARTLY_E2E_ENDPOINT=https://test-1.absmartly.com/v1
ABSMARTLY_E2E_API_KEY=your-api-key-here
ABSMARTLY_E2E_PROFILE=e2e
ABSMARTLY_E2E_APPLICATION=e2e-tests
ABSMARTLY_E2E_ENVIRONMENT=production
ABSMARTLY_E2E_UNITS=100
ABSMARTLY_E2E_TIMEOUT=60
